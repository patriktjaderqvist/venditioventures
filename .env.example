# Admin passphrase hash (SHA-256)
# Generate with: echo -n "your-passphrase" | shasum -a 256
VITE_ADMIN_HASH=

# Web3Forms access key (free, get yours at https://web3forms.com)
# Without this, contact form falls back to mailto:
VITE_WEB3FORMS_KEY=

# Plausible Analytics domain (set this in index.html)
# Sign up at https://plausible.io
